# Copy to .env and set only the providers enabled for the deployment.
# Never expose any of these values in browser/client-side code.

# Structured job-data APIs
THEIRSTACK_API_KEY=
SERPAPI_API_KEY=
HIMALAYAS_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Opt-in fallback / enrichment providers
BRIGHTDATA_API_KEY=
MERGE_API_KEY=

# Self-hosted JobSpy API, if used
JOBSPY_API_URL=
JOBSPY_API_KEY=
